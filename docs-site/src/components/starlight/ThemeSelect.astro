---
import { docsThemes } from '../../utils/doc-themes';
---

<docs-theme-select>
  <button
    type="button"
    class="docs-theme-trigger"
    data-theme-trigger
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Select docs theme"
  >
    <svg aria-hidden="true" class="docs-theme-icon" viewBox="0 0 24 24">
      <path
        d="m21.32 9.55-1.89-.63.89-1.78A1 1 0 0 0 20.13 6L18 3.87a1 1 0 0 0-1.15-.19l-1.78.89-.63-1.89A1 1 0 0 0 13.5 2h-3a1 1 0 0 0-.95.68l-.63 1.89-1.78-.89A1 1 0 0 0 6 3.87L3.87 6a1 1 0 0 0-.19 1.15l.89 1.78-1.89.63a1 1 0 0 0-.68.94v3a1 1 0 0 0 .68.95l1.89.63-.89 1.78A1 1 0 0 0 3.87 18L6 20.13a1 1 0 0 0 1.15.19l1.78-.89.63 1.89a1 1 0 0 0 .95.68h3a1 1 0 0 0 .95-.68l.63-1.89 1.78.89a1 1 0 0 0 1.13-.19L20.13 18a1 1 0 0 0 .19-1.15l-.89-1.78 1.89-.63a1 1 0 0 0 .68-.94v-3a1 1 0 0 0-.68-.95ZM20 12.78l-1.2.4A2 2 0 0 0 17.64 16l.57 1.14-1.1 1.1-1.11-.6a2 2 0 0 0-2.79 1.16l-.4 1.2h-1.59l-.4-1.2A2 2 0 0 0 8 17.64l-1.14.57-1.1-1.1.6-1.11a2 2 0 0 0-1.16-2.82l-1.2-.4v-1.56l1.2-.4A2 2 0 0 0 6.36 8l-.57-1.11 1.1-1.1L8 6.36a2 2 0 0 0 2.82-1.16l.4-1.2h1.56l.4 1.2A2 2 0 0 0 16 6.36l1.14-.57 1.1 1.1-.6 1.11a2 2 0 0 0 1.16 2.79l1.2.4v1.59ZM12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm0 6a2 2 0 1 1 0-4 2 2 0 0 1 0 4Z"
      ></path>
    </svg>
    <span class="docs-theme-current" data-current-label>Default Dark</span>
    <svg aria-hidden="true" class="docs-theme-caret" viewBox="0 0 24 24">
      <path d="M17 9.17a1 1 0 0 0-1.41 0L12 12.71 8.46 9.17a1 1 0 1 0-1.41 1.42l4.24 4.24a1 1 0 0 0 1.42 0L17 10.59a1 1 0 0 0 0-1.42Z"></path>
    </svg>
  </button>

  <div class="docs-theme-popover" data-theme-popover hidden>
    <div class="docs-theme-panel">
      <ul class="docs-theme-list" role="menu" aria-label="Select docs theme">
        {
          docsThemes.map(({ id, label }) => (
            <li>
              <button
                type="button"
                class="docs-theme-option"
                role="menuitemradio"
                tabindex="-1"
                aria-selected="false"
                aria-checked="false"
                data-active="false"
                data-theme-option={id}
                data-theme-label={label}
              >
                <span>{label}</span>
              </button>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</docs-theme-select>

<script is:inline>
  window.DocsThemeProvider?.updatePickers();
</script>

<script>
  type DocsThemeProviderApi = {
    setTheme(theme: string): string;
    updatePickers(theme?: string): void;
  };

  const getThemeProvider = (): DocsThemeProviderApi | undefined =>
    (window as typeof window & { DocsThemeProvider?: DocsThemeProviderApi })
      .DocsThemeProvider;

  class DocsThemeSelect extends HTMLElement {
    handleDocumentPointerDown = (event: PointerEvent) => {
      if (!(event.target instanceof Node) || this.contains(event.target)) return;
      this.closeMenu();
    };

    handleDocumentKeyDown = (event: KeyboardEvent) => {
      if (event.key !== 'Escape') return;
      this.closeMenu();
      this.trigger?.focus();
    };

    handleTriggerClick = () => {
      this.toggleMenu();
    };

    handleTriggerKeyDown = (event: KeyboardEvent) => {
      if (!['ArrowDown', 'ArrowUp', 'Enter', ' '].includes(event.key)) return;
      event.preventDefault();
      this.openMenu(event.key === 'ArrowUp' ? 'last' : 'active');
    };

    handleOptionClick = (event: Event) => {
      if (!(event.currentTarget instanceof HTMLButtonElement)) return;
      const theme = event.currentTarget.dataset.themeOption;
      if (!theme) return;
      getThemeProvider()?.setTheme(theme);
      this.closeMenu();
      this.trigger?.focus();
    };

    handleOptionKeyDown = (event: KeyboardEvent) => {
      if (!(event.currentTarget instanceof HTMLButtonElement)) return;
      const optionIndex = this.options.indexOf(event.currentTarget);
      if (optionIndex === -1) return;

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        this.options[(optionIndex + 1) % this.options.length]?.focus();
        return;
      }

      if (event.key === 'ArrowUp') {
        event.preventDefault();
        this.options[(optionIndex - 1 + this.options.length) % this.options.length]?.focus();
        return;
      }

      if (event.key === 'Home') {
        event.preventDefault();
        this.options[0]?.focus();
        return;
      }

      if (event.key === 'End') {
        event.preventDefault();
        this.options[this.options.length - 1]?.focus();
        return;
      }

      if (event.key === 'Tab') {
        this.closeMenu();
      }
    };

    trigger?: HTMLButtonElement | null;
    popover?: HTMLElement | null;
    options: HTMLButtonElement[] = [];

    connectedCallback() {
      this.trigger = this.querySelector('[data-theme-trigger]');
      this.popover = this.querySelector('[data-theme-popover]');
      this.options = Array.from(this.querySelectorAll('[data-theme-option]'));
      this.dataset.open = this.dataset.open || 'false';

      this.trigger?.addEventListener('click', this.handleTriggerClick);
      this.trigger?.addEventListener('keydown', this.handleTriggerKeyDown);
      this.options.forEach((option) => option.addEventListener('click', this.handleOptionClick));
      this.options.forEach((option) => option.addEventListener('keydown', this.handleOptionKeyDown));
      document.addEventListener('pointerdown', this.handleDocumentPointerDown);
      document.addEventListener('keydown', this.handleDocumentKeyDown);
      getThemeProvider()?.updatePickers();
    }

    disconnectedCallback() {
      this.trigger?.removeEventListener('click', this.handleTriggerClick);
      this.trigger?.removeEventListener('keydown', this.handleTriggerKeyDown);
      this.options.forEach((option) => option.removeEventListener('click', this.handleOptionClick));
      this.options.forEach((option) => option.removeEventListener('keydown', this.handleOptionKeyDown));
      document.removeEventListener('pointerdown', this.handleDocumentPointerDown);
      document.removeEventListener('keydown', this.handleDocumentKeyDown);
    }

    openMenu(target: 'active' | 'first' | 'last' = 'active') {
      if (!this.popover || !this.trigger) return;
      this.popover.hidden = false;
      this.dataset.open = 'true';
      this.trigger.setAttribute('aria-expanded', 'true');

      const activeOption =
        this.options.find((option) => option.dataset.active === 'true') || this.options[0];
      const fallbackOption = target === 'last' ? this.options[this.options.length - 1] : this.options[0];
      (target === 'active' ? activeOption : fallbackOption)?.focus();
    }

    toggleMenu() {
      if (this.popover?.hidden) {
        this.openMenu();
        return;
      }
      this.closeMenu();
    }

    closeMenu() {
      if (!this.popover || !this.trigger) return;
      this.popover.hidden = true;
      this.dataset.open = 'false';
      this.trigger.setAttribute('aria-expanded', 'false');
    }
  }

  if (!customElements.get('docs-theme-select')) {
    customElements.define('docs-theme-select', DocsThemeSelect);
  }
</script>

