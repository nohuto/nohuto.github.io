---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import ViewModeSwitcher from 'starlight-view-modes/components/ViewModeSwitcher.astro';

const { entry } = Astro.locals.starlightRoute;
const isTemplateSplash = entry.data.template === 'splash';
---

{
  isTemplateSplash ? (
    <Default />
  ) : (
    <div class="docs-page-title-row">
      <Default />
      <div class="docs-page-title-switcher">
        <ViewModeSwitcher type="social-links" />
      </div>
    </div>
  )
}

<style>
  .docs-page-title-row {
    display: block;
  }

  .docs-page-title-switcher {
    display: none;
    align-items: center;
    justify-content: flex-end;
    margin-top: 0.35rem;
  }

  :global(body:has(.starlight-view-modes-zen-mode-no-header)) .docs-page-title-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    column-gap: 0.8rem;
  }

  :global(body:has(.starlight-view-modes-zen-mode-no-header)) .docs-page-title-switcher {
    display: inline-flex;
    margin-top: 1.05rem;
  }

  :global(body:has(.starlight-view-modes-zen-mode-no-header) .docs-page-title-switcher a) {
    color: var(--sl-color-gray-2);
  }

  :global(body:has(.starlight-view-modes-zen-mode-no-header) .docs-page-title-switcher a:hover),
  :global(body:has(.starlight-view-modes-zen-mode-no-header) .docs-page-title-switcher a:focus-visible) {
    color: var(--sl-color-accent-high);
  }

  @media (max-width: 50rem) {
    :global(body:has(.starlight-view-modes-zen-mode-no-header)) .docs-page-title-row {
      grid-template-columns: minmax(0, 1fr);
    }

    :global(body:has(.starlight-view-modes-zen-mode-no-header)) .docs-page-title-switcher {
      margin-top: 0.5rem;
      justify-content: flex-start;
    }
  }
</style>
