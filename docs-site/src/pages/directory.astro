---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getDocsDirectoryData } from '../data/projects-directory';

const { repos } = await getDocsDirectoryData();
---

<StarlightPage
  frontmatter={{
    title: 'Documentation Directory',
    description: 'Browse documentation repositories by topic and open each project docs tree.',
    template: 'splash',
    hideBreadcrumbs: true,
    tableOfContents: false,
  }}
  hasSidebar={false}
>
  <section class="docs-directory">
    <p class="docs-directory-description">
      For now, this only includes repositories that have more than a few lines of MD content.
    </p>
    <p class="docs-directory-results-meta">
      {repos.length} {repos.length === 1 ? 'repository' : 'repositories'}
    </p>
    <div class="docs-directory-grid">
      {
        repos.map((repo) => (
          <a
            class="docs-directory-card"
            href={repo.docsUrl}
          >
            <h2 class="docs-directory-card-title">{repo.title}</h2>
            <p class="docs-directory-card-description">{repo.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</StarlightPage>
